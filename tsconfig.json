{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "jsx": "react",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.jsx",
    "**/*.js",
    "app/_layout.tsx",
    "app/index.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}